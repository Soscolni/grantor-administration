# Copy to .env and fill in. .env is gitignored.

# ---- Server ----
PORT=3002

# ---- Monday ----
# Personal API token: Monday avatar -> Developers -> My Access Tokens.
# Must have access to all four boards below.
MONDAY_API_TOKEN=

# Optional shared secret. If set, the Monday automation URL must include
# ?secret=<this>.
WEBHOOK_SHARED_SECRET=

# ---- Boards (ids confirmed) ----
# פעימות — the trigger board. Events from any other board are ignored.
BOARD_PEIMOT=5097251047
# חשבוניות וגביה — the bridge creates a row here.
BOARD_INVOICES=5097251687
# (הגשות מענקים 5097243021 and הסכמים 5097242066 are reached via the links below.)

# ---- Column ids (fill from `npm run discover-boards -- 5097243021 5097242066 5097251047 5097251687`) ----
# On a פעימה row:
COL_PEIMA_AMOUNT=          # numbers — this installment's amount P
COL_PEIMA_TO_GRANT=        # board_relation — link to its הגשת מענק
COL_PEIMA_ORDER=           # optional — date/sequence column to order installments by.
                           # Leave blank to order by item id (creation order).

# On a הגשת מענק row:
COL_GRANT_WINNING=         # numbers — winning amount W
COL_GRANT_TO_AGREEMENT=    # board_relation — link to its הסכם
COL_GRANT_TO_PEIMOT=       # board_relation — link to all its פעימות (to gather siblings)

# On a הסכם row:
COL_AGREEMENT_RATE=        # numbers — commission rate (total = W × rate)
COL_AGREEMENT_CAP=         # numbers — per-installment cap (the 25%)

# On חשבוניות וגביה (output):
COL_INVOICE_AMOUNT=        # numbers — where F is written (the explanation goes in the item name)

# ---- Percentage storage ----
# How rate/cap are stored on הסכם. Leave blank for auto (value > 1 is treated as
# a percent and divided by 100). Set to 1 to force "percent" (e.g. 25 -> 0.25),
# or 0 to force "fraction" (e.g. 0.25 stays 0.25).
RATE_AS_PERCENT=
CAP_AS_PERCENT=
