# Copy this file to .env and fill in the blanks. .env is gitignored.

# ---- Server ----
PORT=3001

# ---- Rivhit ----
# Demo merchant by default. Swap for the real api_token when going live.
RIVHIT_API_TOKEN=0279BF82-CD57-49BA-837C-930F0E2EB805

# ---- Monday ----
# Personal API token: Monday avatar -> Developers -> My Access Tokens.
# Must belong to a user with access to MONDAY_BOARD_ID and to the linked
# customer-library board.
MONDAY_API_TOKEN=

# Required. The bridge ignores webhook events from any other board.
MONDAY_BOARD_ID=

# Required if you want auth. The Monday automation URL must include ?secret=<this>.
WEBHOOK_SHARED_SECRET=

# ---- Main board column IDs (discover with `npm run discover-columns -- <board_id>`) ----
# board_relation column linking the row to the customer-library record.
COL_CUSTOMER_RELATION=

# Mirror column on the main board that shows the customer's "אופן דרישת תשלום"
# (mirrored from the customer-library status column). Its display value
# decides which Rivhit document_type the invoice flow issues, via DOC_TYPE_MAP.
COL_DOC_TYPE_MIRROR=

# date column for the document's issue_date. If empty, today is used.
COL_ISSUE_DATE=

# text column holding the pre-VAT amount for the single line item.
# Strings like "15,000.00" are accepted; commas and currency symbols stripped.
COL_AMOUNT=

# status column. Set STATUS_DONE_LABEL and STATUS_GENERATING_LABEL to existing
# labels on this column (e.g. "הופקה חשבונית", "ממתין").
COL_STATUS=

# text column where Rivhit's document_number is written on success.
# Leave blank if the column is auto-filled by a Rivhit -> Monday sync;
# we don't want to race with that.
COL_DOC_NUMBER=

# link column where Rivhit's document_link (PDF) is written on success
# for the invoice flow.
COL_PDF_LINK=

# link column where the receipt-flow document_link (PDF) is written on
# success. Leave blank to fall back to posting it as an item update only.
COL_RECEIPT_PDF_LINK=

# ---- Customer-library board ----
# Numbers column on the customer-library board holding each customer's
# Rivhit numeric customer_id. The bridge reads this via COL_CUSTOMER_RELATION.
CUSTOMER_LIBRARY_RIVHIT_ID_COL=

# ---- Doc-type mapping (invoice flow only) ----
# JSON object mapping the mirror labels in COL_DOC_TYPE_MIRROR to Rivhit
# numeric document_type IDs. Hebrew labels are fine; whitespace normalized
# before matching. קבלה is NOT here — receipts are a separate flow
# (POST /monday/webhook/receipt) and use RIVHIT_RECEIPT_TYPE below.
DOC_TYPE_MAP={"חשבונית מס":1,"חשבון חיוב":26}

# Rivhit document_type for the receipt flow. Default 2 (חשבון קבלה).
RIVHIT_RECEIPT_TYPE=2

# Rivhit payment_type sent on receipt documents. Required by Rivhit for any
# receipt-type document (otherwise error_code=-86 "לא נשלחו תשלומים לקבלה").
# Probe scripts/probe-payment-types.js prints the full list for the current
# merchant. 9 = העברה בנקאית.
RIVHIT_RECEIPT_PAYMENT_TYPE=9

# Israeli VAT rate as a fraction (0.18 = 18%). Used to gross up the pre-VAT
# amount from numeric_mm3w2bn0 before sending it to Rivhit doc types whose
# Document.TypeList entry has price_include_vat=true (e.g. type 2 חשבון קבלה,
# type 26 חשבון חיוב). Update this when the rate changes.
VAT_RATE=0.18

# ---- Status labels ----
# Existing labels on COL_STATUS. Leave STATUS_GENERATING_LABEL blank to skip
# the in-progress transition.
STATUS_GENERATING_LABEL=ממתין
STATUS_DONE_LABEL=הופקה חשבונית
