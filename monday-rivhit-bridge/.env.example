# Copy this file to .env and fill in the blanks.
# .env is gitignored.

# ---- Server ----
PORT=3001

# ---- Rivhit ----
# Demo merchant by default. Swap for the real api_token when going live.
RIVHIT_API_TOKEN=0279BF82-CD57-49BA-837C-930F0E2EB805

# ---- Monday ----
# Personal API token: Monday avatar -> Developers -> My Access Tokens.
MONDAY_API_TOKEN=

# Optional. If set, the webhook ignores rows from any other board.
MONDAY_BOARD_ID=

# Optional. If set, the Monday automation URL must include ?secret=<this>.
WEBHOOK_SHARED_SECRET=

# ---- Column IDs ----
# Discover with: npm run discover-columns -- <board_id>
# Paste the `id` (not the title) of each column below.

# Main-row columns:
COL_CUSTOMER_ID=
COL_CUSTOMER_NAME=
COL_DOC_TYPE=
COL_ISSUE_DATE=
COL_COMMENTS=
COL_STATUS=
COL_DOC_NUMBER=
COL_PDF_LINK=
COL_LAST_ERROR=

# Subitem columns (same board's subitem-board):
SUBCOL_QTY=
SUBCOL_PRICE=
SUBCOL_CATALOG=
