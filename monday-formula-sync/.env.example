# Copy this file to .env and fill in the blanks. .env is gitignored.

# ---- Server ----
# 3002 so this runs alongside rivhit-poc (3000) and monday-rivhit-bridge (3001).
PORT=3002

# ---- Monday ----
# Personal API token: Monday avatar -> Developers -> My Access Tokens.
# Must belong to a user with access to the board you're syncing.
# NOTE: this service pins API-Version 2025-01 in lib/monday.js — that's the
# first version where formula columns expose their computed value.
MONDAY_API_TOKEN=

# Optional but recommended. If set, webhook events from any other board are
# ignored (returns 200 "skipped").
MONDAY_BOARD_ID=

# Optional shared secret. If set, the Monday automation URL must include
# ?secret=<this> in the webhook URL.
WEBHOOK_SHARED_SECRET=

# ---- What to copy ----
# Default formula -> number column mapping, used when the webhook URL does NOT
# carry ?formula=&target= query params. JSON object { formulaColId: numberColId }.
# Supports several pairs (one button click syncs them all). Discover ids with
# `npm run discover-columns -- <board_id>`.
#
# Leave blank if you'd rather pass column ids per-automation in the webhook URL:
#   .../monday/webhook/formula-sync?formula=<formulaColId>&target=<numberColId>
SYNC_PAIRS={"formula_abc":"numeric_xyz"}
