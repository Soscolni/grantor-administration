# Copy this file to .env and fill in the blanks. .env is gitignored.
# Never put a real MONDAY_API_TOKEN in THIS file — it is committed.

# ---- Server ----
# Default 3003 so this can run alongside the other bridges (3000-3002).
PORT=3003

# ---- Monday ----
# Personal API token: Monday avatar -> Developers -> My Access Tokens.
# Must belong to a user with access to BOARD_TASKS and its subitems board.
# Leave blank here; set the real value in .env.
MONDAY_API_TOKEN=

# Optional. If set, the Monday automation URL must include ?secret=<this>.
WEBHOOK_SHARED_SECRET=

# The board the button lives on. Webhook events from any other board are ignored.
# Ships as a default (5098132295) so it works without being set; override here.
BOARD_TASKS=5098132295

# ---- Column IDs (discover with `npm run discover`; shipped as defaults in server.js) ----
# The "סוג המענק" column on BOARD_TASKS. Its value (e.g. "Pre-Seed") is used
# verbatim as the Google Sheet TAB name. (Dropdown column on board 5098132295.)
COL_GRANT_TYPE=dropdown_mm3ykhzk

# A TEXT column on the SUBITEMS board where each task's "stage" is written.
# The subitem NAME holds the task description; this column holds the stage.
# If the subitems board has no text column yet, create one once with:
#   npm run discover -- create-stage-col <subitemsBoardId> "Stage"
SUBITEM_STAGE_COL=text_mm45tada

# ---- Google Sheet ----
# The public (link-shared, "anyone with the link can view") spreadsheet whose
# tabs are named after grant types. Read via the gviz CSV export endpoint —
# no credentials, no googleapis. Ships as a default; override here if it moves.
GSHEET_ID=13f658G5KXGbmKvXR7m1U_j5mYX4Fd0upgWqTJwE6scc
