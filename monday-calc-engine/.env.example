# Copy to .env and fill in. .env is gitignored.
# On monday-code, set these as app secrets/variables instead; monday-code
# injects PORT for you.

# monday-code sets PORT automatically (often 8080). Only needed for local runs.
PORT=8080

# Your app's Signing Secret: Developer Center -> your app -> Basic Information.
# Verifies every request Monday sends. REQUIRED in production.
MONDAY_SIGNING_SECRET=

# ---- Local dev only ----
# Set to 1 to bypass JWT verification and use MONDAY_API_TOKEN below, so you can
# curl the endpoints without Monday. NEVER set this on a deployed app.
ALLOW_UNSIGNED=

# Personal API token used only when ALLOW_UNSIGNED=1 (local testing).
MONDAY_API_TOKEN=
